# Copiar a .env.local y completar con las credenciales reales del proyecto
# de Supabase Cloud (Project Settings -> Database -> Connect).

# Runtime de la app: pooler en modo transaccion (serverless-friendly)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres"

# drizzle-kit (generate/migrate): session pooler (puerto 5432), requerido para
# DDL. Usar el pooler en vez de la conexion directa si la red no tiene salida
# IPv6 (el host directo de Supabase solo resuelve a IPv6).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres"

# Supabase Auth / Storage / Realtime (supabase-js) — Modulo 1
# Project Settings -> API, seccion "API Keys" (sistema nuevo publishable/secret)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<...>"
SUPABASE_SECRET_KEY="sb_secret_<...>"

# URL publica de esta app (sin slash final) — usada para construir el
# emailRedirectTo del magic link de Instituciones (Modulo 10, /portal). No
# se deriva de headers de la request (fragil detras de un reverse proxy en
# produccion). Dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
